@model Product

<h2>Додати товар</h2>

<form asp-action="CreateProduct" method="post">
    <div class="form-group">
        <label for="Name">Name</label>
        <input type="text" name="Name" class="form-control" required />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="Description">Description</label>
        <textarea name="Description" class="form-control" required></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>

    </div>

    <div class="form-group">
        <label for="Price">Price</label>
        <input type="number" name="Price" step="0.01" class="form-control" required />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label for="StockQuantity">Quantity</label>
        <input type="number" name="StockQuantity" class="form-control" required />
        <span asp-validation-for="StockQuantity" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Додати товар</button>
</form>

@if (ViewBag.Message != null)
{
    <p>@ViewBag.Message</p>
}
else if (ViewBag.Product != null)
{
    <h3>Передані дані:</h3>
    <p><strong>Name:</strong> @ViewBag.Product.Name</p>
    <p><strong>Description:</strong> @ViewBag.Product.Description</p>
    <p><strong>Price:</strong> @ViewBag.Product.Price</p>
    <p><strong>Quantity:</strong> @ViewBag.Product.StockQuantity</p>
}
